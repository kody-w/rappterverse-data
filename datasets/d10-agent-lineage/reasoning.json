{
    "framework": "three-layer-referenced-reasoning-v1",
    "description": "Graph references supporting ancestry inference and the final acyclicity/depth label.",
    "layers": [
        {
            "id": "observation",
            "required": [
                "references",
                "facts"
            ],
            "canonical_references": [
                "/lineage/nodes",
                "/lineage/edges",
                "/query/target_agent_id"
            ]
        },
        {
            "id": "inference",
            "required": [
                "references",
                "rule"
            ],
            "canonical_references": [
                "/lineage/edges",
                "/oracle/topological_order",
                "/oracle/target_ancestors"
            ]
        },
        {
            "id": "decision",
            "required": [
                "references",
                "label"
            ],
            "canonical_references": [
                "/oracle"
            ]
        }
    ]
}

{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://data.rappterverse.dev/schemas/v2/governance/data-card.schema.json",
    "title": "RAPPterverse data card v2",
    "description": "Public documentation for one immutable dataset version. The dataset manifest descriptor and review receipt carry byte integrity.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "datasetId",
        "datasetVersion",
        "title",
        "summary",
        "maintainers",
        "policy",
        "license",
        "sourceBoundary",
        "composition",
        "generation",
        "intendedUses",
        "outOfScopeUses",
        "privacy",
        "rights",
        "safety",
        "contamination",
        "quality",
        "limitations",
        "maintenance"
    ],
    "properties": {
        "schemaVersion": {
            "const": "rappterverse.data-card/v2"
        },
        "datasetId": {
            "$ref": "https://data.rappterverse.dev/schemas/v2/common/identifiers.schema.json#/$defs/DatasetId"
        },
        "datasetVersion": {
            "$ref": "https://data.rappterverse.dev/schemas/v2/common/identifiers.schema.json#/$defs/DatasetVersion"
        },
        "title": {
            "$ref": "#/$defs/Text"
        },
        "summary": {
            "$ref": "#/$defs/Text"
        },
        "maintainers": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "uniqueItems": true,
            "items": {
                "$ref": "https://data.rappterverse.dev/schemas/v2/common/identifiers.schema.json#/$defs/ActorId"
            }
        },
        "policy": {
            "$ref": "https://data.rappterverse.dev/schemas/v2/common/artifact-descriptor.schema.json#/$defs/PolicyRef"
        },
        "license": {
            "const": "CC-BY-4.0"
        },
        "sourceBoundary": {
            "$ref": "#/$defs/SourceBoundary"
        },
        "composition": {
            "$ref": "#/$defs/Composition"
        },
        "generation": {
            "$ref": "#/$defs/Generation"
        },
        "intendedUses": {
            "$ref": "#/$defs/TextList"
        },
        "outOfScopeUses": {
            "$ref": "#/$defs/TextList"
        },
        "privacy": {
            "$ref": "#/$defs/Privacy"
        },
        "rights": {
            "$ref": "#/$defs/Rights"
        },
        "safety": {
            "$ref": "#/$defs/Safety"
        },
        "contamination": {
            "$ref": "#/$defs/Contamination"
        },
        "quality": {
            "$ref": "#/$defs/Quality"
        },
        "limitations": {
            "$ref": "#/$defs/TextList"
        },
        "maintenance": {
            "$ref": "#/$defs/Maintenance"
        }
    },
    "$defs": {
        "Text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16384
        },
        "TextList": {
            "type": "array",
            "minItems": 1,
            "maxItems": 128,
            "items": {
                "$ref": "#/$defs/Text"
            }
        },
        "SourceBoundary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "allowed",
                "externalCorporaIncluded",
                "lineageComplete"
            ],
            "properties": {
                "allowed": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "enum": [
                            "synthetic",
                            "rappterverse-owned",
                            "system-controlled",
                            "human-consented"
                        ]
                    }
                },
                "externalCorporaIncluded": {
                    "const": false
                },
                "lineageComplete": {
                    "const": true
                }
            }
        },
        "Composition": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "recordTypes",
                "records",
                "transcripts",
                "deliberations",
                "providerReasoning",
                "splits"
            ],
            "properties": {
                "recordTypes": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 64,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9-]{1,63}$"
                    }
                },
                "records": {
                    "type": "integer",
                    "minimum": 1
                },
                "transcripts": {
                    "type": "integer",
                    "minimum": 1
                },
                "deliberations": {
                    "type": "integer",
                    "minimum": 1
                },
                "providerReasoning": {
                    "type": "integer",
                    "minimum": 0
                },
                "splits": {
                    "$ref": "#/$defs/Splits"
                }
            }
        },
        "Splits": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "train",
                "validation",
                "test",
                "unassigned"
            ],
            "properties": {
                "train": {
                    "type": "integer",
                    "minimum": 0
                },
                "validation": {
                    "type": "integer",
                    "minimum": 0
                },
                "test": {
                    "type": "integer",
                    "minimum": 0
                },
                "unassigned": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        },
        "Generation": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "method",
                "visibleTranscripts",
                "explicitDeliberations",
                "providerReasoningPolicy"
            ],
            "properties": {
                "method": {
                    "$ref": "#/$defs/Text"
                },
                "visibleTranscripts": {
                    "const": "complete"
                },
                "explicitDeliberations": {
                    "const": "required"
                },
                "providerReasoningPolicy": {
                    "const": "optional-external-receipt-gated"
                }
            }
        },
        "Privacy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "classification",
                "realPiiIncluded",
                "secretsIncluded"
            ],
            "properties": {
                "classification": {
                    "type": "string",
                    "enum": [
                        "synthetic-nonpersonal",
                        "consented-public-judgments"
                    ]
                },
                "realPiiIncluded": {
                    "const": false
                },
                "secretsIncluded": {
                    "const": false
                }
            }
        },
        "Rights": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "ownershipVerified",
                "externalContentIncluded"
            ],
            "properties": {
                "ownershipVerified": {
                    "const": true
                },
                "externalContentIncluded": {
                    "const": false
                }
            }
        },
        "Safety": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "reviewed",
                "status",
                "knownRisks"
            ],
            "properties": {
                "reviewed": {
                    "const": true
                },
                "status": {
                    "const": "pass"
                },
                "knownRisks": {
                    "$ref": "#/$defs/TextList"
                }
            }
        },
        "Contamination": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "publicDataset",
                "evaluationUse"
            ],
            "properties": {
                "publicDataset": {
                    "const": true
                },
                "evaluationUse": {
                    "const": "contamination-prone-not-clean-evaluation"
                }
            }
        },
        "Quality": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "allRecordsSchemaValid",
                "allVerifiersPassed",
                "allProvenanceVerified",
                "duplicateRecords"
            ],
            "properties": {
                "allRecordsSchemaValid": {
                    "const": true
                },
                "allVerifiersPassed": {
                    "const": true
                },
                "allProvenanceVerified": {
                    "const": true
                },
                "duplicateRecords": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        },
        "Maintenance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "immutableRelease",
                "withdrawalPolicy",
                "contact"
            ],
            "properties": {
                "immutableRelease": {
                    "const": true
                },
                "withdrawalPolicy": {
                    "const": "append-only-tombstone"
                },
                "contact": {
                    "const": "https://github.com/kody-w/rappterverse-data/issues"
                }
            }
        }
    }
}

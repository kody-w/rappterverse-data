{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://data.rappterverse.dev/schemas/v2/governance/rights-statements.schema.json",
    "title": "RAPPterverse closed rights statement registry v2",
    "description": "The complete, digest-pinned registry of rights statements accepted by the v2 public release contract.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "registryId",
        "registryVersion",
        "effectiveAt",
        "defaultAction",
        "dataLicense",
        "statements"
    ],
    "properties": {
        "schemaVersion": {
            "const": "rappterverse.rights-statements/v2"
        },
        "registryId": {
            "const": "rappterverse-publication-rights"
        },
        "registryVersion": {
            "const": "2.0.0"
        },
        "effectiveAt": {
            "$ref": "https://data.rappterverse.dev/schemas/v2/common/identifiers.schema.json#/$defs/UtcTimestamp"
        },
        "defaultAction": {
            "const": "deny"
        },
        "dataLicense": {
            "const": "CC-BY-4.0"
        },
        "statements": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {
                "$ref": "#/$defs/Statement"
            }
        }
    },
    "$defs": {
        "SourceType": {
            "type": "string",
            "enum": [
                "deterministic-synthetic",
                "model-generated-synthetic",
                "rappterverse-repository",
                "system-controlled-agent",
                "consented-human-judgment"
            ]
        },
        "AttestationField": {
            "type": "string",
            "enum": [
                "sourceId",
                "generatorCommit",
                "repository",
                "commit",
                "path",
                "blobSha256",
                "agentId",
                "ownershipEvidence",
                "publicDataConsent",
                "license",
                "consentedAt",
                "consentEvidence"
            ]
        },
        "Attestation": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "sourceType",
                "requiredFields"
            ],
            "properties": {
                "sourceType": {
                    "$ref": "#/$defs/SourceType"
                },
                "requiredFields": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 8,
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/AttestationField"
                    }
                }
            }
        },
        "Statement": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "rightsStatementId",
                "status",
                "rightsBasis",
                "sourceTypes",
                "attestations",
                "statement"
            ],
            "properties": {
                "rightsStatementId": {
                    "type": "string",
                    "pattern": "^rights-[a-z0-9][a-z0-9.-]{0,119}$"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "revoked"
                    ]
                },
                "rightsBasis": {
                    "type": "string",
                    "enum": [
                        "synthetic",
                        "rappterverse-owned"
                    ]
                },
                "sourceTypes": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/SourceType"
                    }
                },
                "attestations": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "items": {
                        "$ref": "#/$defs/Attestation"
                    }
                },
                "statement": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 2048
                }
            }
        }
    }
}

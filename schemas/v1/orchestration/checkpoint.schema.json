{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://data.rappterverse.dev/schemas/v1/orchestration/checkpoint.schema.json",
    "title": "RAPPterverse Durable Checkpoint",
    "description": "Repository-backed worker state sufficient for stateless reconstruction after process, session, or worktree loss.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "checkpointId",
        "runId",
        "datasetId",
        "threadId",
        "partitionId",
        "sourceCommit",
        "fencingEpoch",
        "state",
        "cursor",
        "inflight",
        "latestValidatedOutput",
        "previousCheckpointSha256",
        "checkpointedAt",
        "checkpointSha256"
    ],
    "properties": {
        "schemaVersion": {
            "const": "rappterverse.checkpoint/v1"
        },
        "checkpointId": {
            "type": "string",
            "pattern": "^urn:rappterverse:checkpoint:sha256:[a-f0-9]{64}$"
        },
        "runId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/RunId"
        },
        "datasetId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/DatasetId"
        },
        "threadId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/ThreadId"
        },
        "partitionId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/PartitionId"
        },
        "sourceCommit": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/GitCommit"
        },
        "fencingEpoch": {
            "type": "integer",
            "minimum": 1
        },
        "state": {
            "type": "string",
            "enum": [
                "READY",
                "LEASED",
                "BATCH_PLANNED",
                "PERMIT_GRANTED",
                "CALLING",
                "VALIDATING",
                "CHECKPOINTED",
                "DRAINED",
                "QUIESCING",
                "CORRUPT"
            ]
        },
        "cursor": {
            "$ref": "#/$defs/Cursor"
        },
        "inflight": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "#/$defs/Inflight"
                }
            ]
        },
        "latestValidatedOutput": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            ]
        },
        "previousCheckpointSha256": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            ]
        },
        "checkpointedAt": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/UtcTimestamp"
        },
        "checkpointSha256": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
        }
    },
    "$defs": {
        "Cursor": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "nextIndex",
                "acceptedCount",
                "rejectedCount",
                "inputDigest"
            ],
            "properties": {
                "nextIndex": {
                    "type": "integer",
                    "minimum": 0
                },
                "acceptedCount": {
                    "type": "integer",
                    "minimum": 0
                },
                "rejectedCount": {
                    "type": "integer",
                    "minimum": 0
                },
                "inputDigest": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            }
        },
        "Inflight": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "batchId",
                "inputDigest",
                "orderedItemIds",
                "plannedAt"
            ],
            "properties": {
                "batchId": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/BatchId"
                },
                "inputDigest": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                },
                "orderedItemIds": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 10000,
                    "items": {
                        "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/StableKey"
                    }
                },
                "plannedAt": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/UtcTimestamp"
                }
            }
        }
    }
}

{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://data.rappterverse.dev/schemas/v1/orchestration/handoff.schema.json",
    "title": "RAPPterverse Stateless Worker Handoff",
    "description": "Exact reconstruction material regenerated at each checkpoint for the next fresh worker.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "handoffId",
        "runId",
        "datasetId",
        "threadId",
        "partitionId",
        "sourceCommit",
        "fencingEpoch",
        "cursor",
        "outstandingBatch",
        "latestValidatedOutput",
        "currentBlocker",
        "recoveryCommand",
        "nextDeterministicAction",
        "lessonHashes",
        "checkpointSha256",
        "generatedAt",
        "handoffSha256"
    ],
    "properties": {
        "schemaVersion": {
            "const": "rappterverse.handoff/v1"
        },
        "handoffId": {
            "type": "string",
            "pattern": "^urn:rappterverse:handoff:sha256:[a-f0-9]{64}$"
        },
        "runId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/RunId"
        },
        "datasetId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/DatasetId"
        },
        "threadId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/ThreadId"
        },
        "partitionId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/PartitionId"
        },
        "sourceCommit": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/GitCommit"
        },
        "fencingEpoch": {
            "type": "integer",
            "minimum": 1
        },
        "cursor": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "nextIndex",
                "inputDigest"
            ],
            "properties": {
                "nextIndex": {
                    "type": "integer",
                    "minimum": 0
                },
                "inputDigest": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            }
        },
        "outstandingBatch": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "batchId",
                        "inputDigest",
                        "orderedItemIds"
                    ],
                    "properties": {
                        "batchId": {
                            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/BatchId"
                        },
                        "inputDigest": {
                            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                        },
                        "orderedItemIds": {
                            "type": "array",
                            "minItems": 1,
                            "maxItems": 10000,
                            "items": {
                                "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/StableKey"
                            }
                        }
                    }
                }
            ]
        },
        "latestValidatedOutput": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            ]
        },
        "currentBlocker": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "code",
                        "safeSummary"
                    ],
                    "properties": {
                        "code": {
                            "type": "string",
                            "pattern": "^[a-z][a-z0-9.-]{0,127}$"
                        },
                        "safeSummary": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 2048
                        }
                    }
                }
            ]
        },
        "recoveryCommand": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "executable",
                "arguments",
                "containsSecrets"
            ],
            "properties": {
                "executable": {
                    "type": "string",
                    "enum": [
                        "python",
                        "python3"
                    ]
                },
                "arguments": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 32,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 512
                    }
                },
                "containsSecrets": {
                    "const": false
                }
            }
        },
        "nextDeterministicAction": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "action",
                "inputDigest"
            ],
            "properties": {
                "action": {
                    "type": "string",
                    "enum": [
                        "claim-lease",
                        "resume-batch",
                        "plan-next-batch",
                        "validate-output",
                        "checkpoint",
                        "drain"
                    ]
                },
                "inputDigest": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            }
        },
        "lessonHashes": {
            "type": "array",
            "uniqueItems": true,
            "maxItems": 128,
            "items": {
                "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
            }
        },
        "checkpointSha256": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
        },
        "generatedAt": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/UtcTimestamp"
        },
        "handoffSha256": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
        }
    }
}

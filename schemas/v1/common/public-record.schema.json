{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://data.rappterverse.dev/schemas/v1/common/public-record.schema.json",
    "title": "RAPPterverse Public Record Envelope",
    "description": "Closed common envelope for every released dataset record. Dataset schemas must further constrain payload.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "datasetId",
        "recordType",
        "recordId",
        "episodeId",
        "sequence",
        "split",
        "eventTime",
        "payload",
        "provenance",
        "generation",
        "governance",
        "integrity"
    ],
    "properties": {
        "schemaVersion": {
            "const": "rappterverse.public-record/v1"
        },
        "datasetId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/DatasetId"
        },
        "recordType": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
        },
        "recordId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/RecordId"
        },
        "episodeId": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/EpisodeId"
        },
        "sequence": {
            "type": "integer",
            "minimum": 0
        },
        "split": {
            "type": "string",
            "enum": [
                "train",
                "validation",
                "test",
                "unassigned"
            ]
        },
        "eventTime": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/UtcTimestamp"
        },
        "payload": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/json-value.schema.json#/$defs/JsonObject"
        },
        "provenance": {
            "$ref": "https://data.rappterverse.dev/schemas/v1/common/provenance.schema.json"
        },
        "generation": {
            "$ref": "#/$defs/Generation"
        },
        "governance": {
            "$ref": "#/$defs/Governance"
        },
        "integrity": {
            "$ref": "#/$defs/Integrity"
        }
    },
    "$defs": {
        "Generation": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "runId",
                "threadId",
                "generatorCommit",
                "seed",
                "model",
                "promptTemplate",
                "transcriptRef",
                "deliberationRef",
                "providerReasoningRef",
                "providerReasoningReviewRef",
                "tools"
            ],
            "properties": {
                "runId": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/RunId"
                },
                "threadId": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/ThreadId"
                },
                "generatorCommit": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/GitCommit"
                },
                "seed": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                },
                "model": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "provider",
                        "modelId",
                        "requestId",
                        "policyHash",
                        "providerReasoningExposed"
                    ],
                    "properties": {
                        "provider": {
                            "type": "string",
                            "pattern": "^[a-z0-9][a-z0-9.-]{0,127}$"
                        },
                        "modelId": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 256
                        },
                        "requestId": {
                            "anyOf": [
                                {
                                    "type": "null"
                                },
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 256
                                }
                            ]
                        },
                        "policyHash": {
                            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                        },
                        "providerReasoningExposed": {
                            "type": "boolean"
                        }
                    }
                },
                "promptTemplate": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "id",
                        "version",
                        "sha256"
                    ],
                    "properties": {
                        "id": {
                            "type": "string",
                            "pattern": "^prompt-[a-z0-9][a-z0-9.-]{0,119}$"
                        },
                        "version": {
                            "type": "string",
                            "pattern": "^v[1-9][0-9]*$"
                        },
                        "sha256": {
                            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                        }
                    }
                },
                "transcriptRef": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                },
                "deliberationRef": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                },
                "providerReasoningRef": {
                    "anyOf": [
                        {
                            "type": "null"
                        },
                        {
                            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                        }
                    ]
                },
                "providerReasoningReviewRef": {
                    "anyOf": [
                        {
                            "type": "null"
                        },
                        {
                            "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                        }
                    ]
                },
                "tools": {
                    "type": "array",
                    "maxItems": 256,
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                            "name",
                            "version",
                            "definitionSha256"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
                            },
                            "version": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 128
                            },
                            "definitionSha256": {
                                "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                            }
                        }
                    }
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "providerReasoningRef": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "providerReasoningRef"
                        ]
                    },
                    "then": {
                        "properties": {
                            "providerReasoningReviewRef": {
                                "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                            },
                            "model": {
                                "properties": {
                                    "providerReasoningExposed": {
                                        "const": true
                                    }
                                }
                            }
                        }
                    },
                    "else": {
                        "properties": {
                            "providerReasoningReviewRef": {
                                "type": "null"
                            }
                        }
                    }
                }
            ]
        },
        "Governance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "license",
                "privacy",
                "safetyLabels",
                "safetyReviewPassed",
                "contamination",
                "quality",
                "dataCardRef",
                "reviewReceiptRef"
            ],
            "properties": {
                "license": {
                    "const": "CC-BY-4.0"
                },
                "privacy": {
                    "type": "string",
                    "enum": [
                        "synthetic-nonpersonal",
                        "consented-public-judgment"
                    ]
                },
                "safetyLabels": {
                    "type": "array",
                    "uniqueItems": true,
                    "maxItems": 64,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z0-9][a-z0-9.-]{0,63}$"
                    }
                },
                "safetyReviewPassed": {
                    "const": true
                },
                "contamination": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "status",
                        "publicSince",
                        "evaluationUse"
                    ],
                    "properties": {
                        "status": {
                            "type": "string",
                            "enum": [
                                "synthetic-public",
                                "public-generated-contamination-risk"
                            ]
                        },
                        "publicSince": {
                            "$ref": "https://data.rappterverse.dev/schemas/v1/common/identifiers.schema.json#/$defs/UtcTimestamp"
                        },
                        "evaluationUse": {
                            "const": "disclose-and-control"
                        }
                    }
                },
                "quality": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "verifierPassed",
                        "verifierRefs",
                        "score"
                    ],
                    "properties": {
                        "verifierPassed": {
                            "const": true
                        },
                        "verifierRefs": {
                            "type": "array",
                            "minItems": 1,
                            "maxItems": 64,
                            "items": {
                                "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                            }
                        },
                        "score": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                        }
                    }
                },
                "dataCardRef": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                },
                "reviewReceiptRef": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            }
        },
        "Integrity": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "canonicalization",
                "payloadSha256",
                "recordSha256"
            ],
            "properties": {
                "canonicalization": {
                    "const": "rappterverse-canonical-json/v1"
                },
                "payloadSha256": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                },
                "recordSha256": {
                    "$ref": "https://data.rappterverse.dev/schemas/v1/common/digest.schema.json#/$defs/Sha256Digest"
                }
            }
        }
    }
}
